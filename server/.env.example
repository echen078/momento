# The port the server will run on locally
PORT=5000

# MongoDB Atlas connection string
# Replace <username>, <password>, and <database>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/<database>?retryWrites=true&w=majority

# Secret key used to sign JWT tokens — replace with a long random string
JWT_SECRET=your_jwt_secret_here